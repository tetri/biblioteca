{
  "types": [
    {"type": "feat", "section": "✨ Features"},
    {"type": "fix", "section": "🐛 Bug Fixes"},
    {"type": "docs", "section": "📝 Documentation"},
    {"type": "style", "section": "💄 Styling"},
    {"type": "refactor", "section": "♻️ Code Refactoring"},
    {"type": "perf", "section": "⚡️ Performance Improvements"},
    {"type": "test", "section": "✅ Tests"},
    {"type": "build", "section": "📦 Build System"},
    {"type": "ci", "section": "👷 CI/CD"},
    {"type": "chore", "section": "🔧 Chores"},
    {"type": "revert", "section": "⏪ Reverts"}
  ],
  "commitUrlFormat": "https://github.com/tetri/biblioteca/commit/{{hash}}",
  "compareUrlFormat": "https://github.com/tetri/biblioteca/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://github.com/tetri/biblioteca/issues/{{id}}"
}
