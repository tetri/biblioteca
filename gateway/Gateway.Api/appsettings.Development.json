{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "userservice-cluster",
        "Match": { "Path": "api/auth/{**catch-all}" }
      },
      "catalog-route": {
        "ClusterId": "catalogservice-cluster",
        "Match": { "Path": "api/catalog/{**catch-all}" }
      },
      "docs-catalog-route": {
        "ClusterId": "catalogservice-cluster",
        "Match": { "Path": "docs/catalog/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/docs/catalog" }]
      },
      "docs-loan-route": {
        "ClusterId": "loanservice-cluster",
        "Match": { "Path": "docs/loan/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/docs/loan" }]
      },
      "frontend-route": {
        "ClusterId": "frontend-cluster",
        "Match": { "Path": "{**catch-all}" }
      }
    },

    "Clusters": {
      "userservice-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://userservice.api:8080/"
          }
        }
      },
      "catalogservice-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://catalogservice.api:8080/"
          }
        }
      },
      "frontend-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:3000/"
          }
        }
      }
    }
  }
}
