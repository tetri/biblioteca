{
  "ReverseProxy": {
    "Routes": {
      "frontend-route": {
        "ClusterId": "frontend-cluster",
        "Match": {
          "Path": "{**catch-all}"
        }
      }
    },
    "Clusters": {
      "frontend-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:3000/"
          }
        }
      }
    }
  }
}
