{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "user": {
        "ClusterId": "user",
        "Order": 0,
        "Match": { "Path": "/user/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/user" }]
      },
      "catalog": {
        "ClusterId": "catalog",
        "Order": 0,
        "Match": { "Path": "/catalog/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/catalog" }]
      },
      "loan": {
        "ClusterId": "loan",
        "Order": 0,
        "Match": { "Path": "/loan/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/loan" }]
      },
      "notification": {
        "ClusterId": "notification",
        "Order": 0,
        "Match": { "Path": "/notification/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/notification" }]
      },
      "frontend": {
        "ClusterId": "frontend",
        "Order": 100,
        "Timeout": "00:00:30",
        "Match": { "Path": "/{**catch-all}" }
      }
    },
    "Clusters": {
      "user": {
        "Destinations": {
          "user1": { "Address": "http://localhost:5146/" }
        }
      },
      "catalog": {
        "Destinations": {
          "catalog1": { "Address": "http://localhost:5147/" }
        }
      },
      "loan": {
        "Destinations": {
          "loan1": { "Address": "http://localhost:5118/" }
        }
      },
      "notification": {
        "Destinations": {
          "notification1": { "Address": "http://localhost:5151/" }
        }
      },
      "frontend": {
        "Destinations": {
          "frontend1": { "Address": "http://localhost:3000/" }
        }
      }
    }
  }
}
