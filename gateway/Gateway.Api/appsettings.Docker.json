{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "user": {
        "ClusterId": "user",
        "Order": 0,
        "Match": { "Path": "/user/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/user" }]
      },
      "catalog": {
        "ClusterId": "catalog",
        "Order": 0,
        "Match": { "Path": "/catalog/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/catalog" }]
      },
      "loan": {
        "ClusterId": "loan",
        "Order": 0,
        "Match": { "Path": "/loan/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/loan" }]
      },
      "notification": {
        "ClusterId": "notification",
        "Order": 0,
        "Match": { "Path": "/notification/{**catch-all}" },
        "Transforms": [{ "PathRemovePrefix": "/notification" }]
      },
      "frontend": {
        "ClusterId": "frontend",
        "Order": 100,
        "Match": { "Path": "/{**catch-all}" }
      }
    },
    "Clusters": {
      "user": {
        "Destinations": {
          "user1": { "Address": "http://userservice:8080/" }
        },
        "HealthCheck": {
          "Active": { "Enabled": true, "Path": "/health" }
        }
      },
      "catalog": {
        "Destinations": {
          "catalog1": { "Address": "http://catalogservice:8080/" }
        },
        "HealthCheck": {
          "Active": { "Enabled": true, "Path": "/health" }
        }
      },
      "loan": {
        "Destinations": {
          "loan1": { "Address": "http://loanservice:8080/" }
        },
        "HealthCheck": {
          "Active": { "Enabled": true, "Path": "/health" }
        }
      },
      "notification": {
        "Destinations": {
          "notification1": { "Address": "http://notificationservice:8080/" }
        },
        "HealthCheck": {
          "Active": { "Enabled": true, "Path": "/health" }
        }
      },
      "frontend": {
        "Destinations": {
          "frontend1": { "Address": "http://frontend:80/" }
        }
      }
    }
  }
}
