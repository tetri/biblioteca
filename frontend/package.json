{
  "name": "@biblioteca/frontend",
  "private": true,
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Sistema de Biblioteca - Frontend React",
  "author": "Biblioteca Team <team@biblioteca.app>",
  "license": "MIT",
  "homepage": "https://github.com/tetri/biblioteca#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tetri/biblioteca.git"
  },
  "bugs": {
    "url": "https://github.com/tetri/biblioteca/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "biblioteca",
    "library",
    "react",
    "shadcn",
    "tailwindcss",
    "vite"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest run",
    "precommit": "npm run lint:staged",
    "lint:staged": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css,md}\"",
    "commitlint": "commitlint --edit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@tanstack/react-query": "^5.99.2",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.9.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "msw": "^2.14.6",
    "tw-animate-css": "^1.3.8",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^8.1.0",
    "vitest": "^4.0.0"
  },
  "allowScripts": {
    "msw@2.14.6": true
  }
}
